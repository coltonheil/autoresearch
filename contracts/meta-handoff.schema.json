{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heilginseng.com/schemas/meta-handoff.schema.json",
  "title": "Meta Creative Handoff Packet",
  "type": "object",
  "required": [
    "schema_version",
    "handoff_id",
    "source_run",
    "generated_at",
    "channel_from",
    "channel_to",
    "activation_policy",
    "records"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "handoff_id": {"type": "string", "minLength": 1},
    "source_run": {
      "type": "object",
      "required": ["product", "run_date", "run_path", "source_summary"],
      "properties": {
        "product": {"type": "string", "minLength": 1},
        "run_date": {"type": "string", "format": "date"},
        "run_path": {"type": "string", "minLength": 1},
        "source_summary": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "channel_from": {"type": "string", "const": "#ginseng-autoresearch"},
    "channel_to": {"type": "string", "const": "#ginseng-retail"},
    "activation_policy": {"type": "string", "const": "draft_only_human_activation_required"},
    "notes": {"type": "string"},
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "product",
          "concept_name",
          "rank",
          "phase",
          "scene",
          "image_path",
          "validation_path",
          "packaging_gate",
          "root_gate",
          "no_humans_gate",
          "copy_variants",
          "headline_variants",
          "primary_text_variants",
          "cta",
          "status"
        ],
        "properties": {
          "asset_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{5,}$"},
          "product": {"type": "string", "minLength": 1},
          "concept_name": {"type": "string", "minLength": 1},
          "rank": {"type": "integer", "minimum": 1},
          "phase": {"type": "string", "enum": ["pilot", "final"]},
          "scene": {"type": "string", "minLength": 1},
          "image_path": {"type": "string", "minLength": 1},
          "validation_path": {"type": "string", "minLength": 1},
          "packaging_gate": {"type": "string", "enum": ["PASS", "FAIL", "WARN"]},
          "root_gate": {"type": "string", "enum": ["PASS", "FAIL", "WARN"]},
          "no_humans_gate": {"type": "string", "enum": ["PASS", "FAIL", "WARN"]},
          "composite_score": {"type": "number"},
          "brand_fit_score": {"type": "number"},
          "copy_variants": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {"type": "string", "minLength": 1}
          },
          "headline_variants": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {"type": "string", "minLength": 1, "maxLength": 255}
          },
          "primary_text_variants": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {"type": "string", "minLength": 1}
          },
          "cta": {"type": "string", "minLength": 1},
          "status": {"type": "string", "const": "ready_for_retail"},
          "operator_notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
